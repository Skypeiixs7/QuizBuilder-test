# After `npx convex dev` (new project), Convex CLI writes CONVEX_* lines here — or copy from Dashboard.
# Never commit real .env.local (gitignored).

CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Next.js + Convex Auth (also set matching secrets in Convex Dashboard for this deployment)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
